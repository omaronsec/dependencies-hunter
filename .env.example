# Telegram Notification (choose one method)

# Method 1: Using 'notify' tool (recommended)
# Install: go install -v github.com/projectdiscovery/notify/cmd/notify@latest
# Configure: ~/.config/notify/provider-config.yaml
USE_NOTIFY=true

# Method 2: Direct Telegram Bot API (fallback)
# Create bot via @BotFather, get token
# Get chat ID from: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# GitHub (for -org mode, must also run: gh auth login)
# No token needed if gh CLI is authenticated

# Rate limiting (seconds between registry checks)
REGISTRY_DELAY=0.5

# Parallel workers for JS analysis
WORKERS=3
